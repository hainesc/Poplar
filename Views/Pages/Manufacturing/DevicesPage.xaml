<Page
    x:Class="Poplar.Views.Pages.Manufacturing.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Poplar.Views.Pages.Manufacturing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Poplar.ViewModels.Pages.Manufacturing"
    Title="Device Management"
    d:DataContext="{d:DesignInstance local:DevicesPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Device Infrastructure" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Manage and monitor discrete manufacturing nodes" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ViewModel.Devices}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DeviceItemViewModel}">
                        <ui:Card
                            Width="260"
                            Margin="0,0,16,16"
                            Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Card Header -->
                                <Grid Grid.Row="0" Margin="16,16,16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="8">
                                        <ui:SymbolIcon FontSize="20" Symbol="Cpu24" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Record.name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Record.device_type, Converter={StaticResource StringToUppercaseConverter}}" />
                                    </StackPanel>

                                    <!-- Status Indicator -->
                                    <Border
                                        Grid.Column="2"
                                        Padding="8,4"
                                        VerticalAlignment="Top"
                                        CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#10000000" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status.is_online}" Value="True">
                                                        <Setter Property="Background" Value="#2000FF00" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status.is_online}" Value="False">
                                                        <Setter Property="Background" Value="#20FF0000" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="9" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="OFFLINE" />
                                                    <Setter Property="Foreground" Value="Gray" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status.is_online}" Value="True">
                                                            <Setter Property="Text" Value="ONLINE" />
                                                            <Setter Property="Foreground" Value="Green" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status.is_online}" Value="False">
                                                            <Setter Property="Text" Value="OFFLINE" />
                                                            <Setter Property="Foreground" Value="Red" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Message Area -->
                                <Border
                                    Grid.Row="1"
                                    Margin="16,0,16,16"
                                    Padding="12"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="8">
                                    <TextBlock
                                        FontSize="11"
                                        FontStyle="Italic"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="{Binding Status.message, FallbackValue='No status data available'}"
                                        TextWrapping="Wrap" />
                                </Border>

                                <!-- Footer -->
                                <Border
                                    Grid.Row="2"
                                    Padding="16,12"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                    <Grid>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="Consolas"
                                            FontSize="10"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Record.protocol}" />
                                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                            <ui:Button
                                                Padding="4"
                                                Command="{Binding DataContext.ViewModel.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=local:DevicesPage}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Edit24}"
                                                Appearance="Transparent" />
                                            <ui:Button
                                                Margin="4,0,0,0"
                                                Padding="4"
                                                Command="{Binding DataContext.ViewModel.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=local:DevicesPage}}"
                                                CommandParameter="{Binding}"
                                                Icon="{ui:SymbolIcon Delete24}"
                                                Appearance="Transparent" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add Button Floating -->
        <ui:Button
            Grid.Row="1"
            Width="56"
            Height="56"
            Margin="0,0,24,24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Appearance="Primary"
            Command="{Binding ViewModel.AddDeviceCommand}"
            CornerRadius="28"
            Icon="{ui:SymbolIcon Add24}" />
    </Grid>
</Page>
