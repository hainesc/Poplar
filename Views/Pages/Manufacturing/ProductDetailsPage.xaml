<Page
    x:Class="Poplar.Views.Pages.Manufacturing.ProductDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:nodify="https://miroiu.github.io/nodify"
    xmlns:local="clr-namespace:Poplar.Views.Pages.Manufacturing"
    xmlns:vm="clr-namespace:Poplar.ViewModels.Pages.Manufacturing"
    Title="Product Configuration Hub"
    d:DataContext="{d:DesignInstance local:ProductDetailsPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Transparent" 
                           Command="{Binding ViewModel.NavigateBackCommand}" 
                           Icon="{ui:SymbolIcon ArrowLeft24}" 
                           Margin="0,0,16,0"
                           Padding="8,4"/>
                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Text="{Binding ViewModel.ProductName, FallbackValue='Product Details'}" />
            </StackPanel>
            <TextBlock
                Margin="48,4,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Manage hardware associations, data tags, traceability schemas, and processing logic." />
        </StackPanel>

        <!-- Configuration Hub Tabs -->
        <TabControl Grid.Row="1">
            
            <!-- 1. Overview & Hardware Tab -->
            <TabItem Header="Hardware Integration">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Associated Devices" />
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Select which devices are responsible for manufacturing this product." Margin="0,4,0,0"/>
                    </StackPanel>

                    <ui:ListView 
                        Grid.Row="1"
                        ItemsSource="{Binding ViewModel.AvailableDevices}"
                        SelectionMode="Multiple">
                        <ui:ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DeviceSelectionItem}">
                                <CheckBox Content="{Binding name}" IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,4"/>
                            </DataTemplate>
                        </ui:ListView.ItemTemplate>
                    </ui:ListView>

                    <ui:Button Grid.Row="2" 
                               Appearance="Primary" 
                               Content="Save Hardware Configuration" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveHardwareCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- 2. PLC Tags Tab -->
            <TabItem Header="PLC Tag Mapping">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding ViewModel.PlcTags}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tag Name" Binding="{Binding name}" Width="150" />
                            <DataGridComboBoxColumn Header="Direction" 
                                                    SelectedItemBinding="{Binding direction}">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="{x:Type sys:String}">
                                        <sys:String>H-&gt;P</sys:String>
                                        <sys:String>P-&gt;H</sys:String>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Byte Offset" Binding="{Binding byteOffset}" Width="100"/>
                            <DataGridTextColumn Header="Bit Offset" Binding="{Binding bitOffset}" Width="100"/>
                            <DataGridTextColumn Header="Data Type" Binding="{Binding valueType}" Width="120"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <ui:Button Grid.Row="1" 
                               Appearance="Primary" 
                               Content="Save Tag Mappings" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveTagsCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- 3. Traceability Tab -->
            <TabItem Header="Audit &amp; Traceability">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <DataGrid Grid.Row="0"
                              ItemsSource="{Binding ViewModel.TraceabilityItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item Name" Binding="{Binding name}" Width="200" />
                            <DataGridTextColumn Header="Data Type" Binding="{Binding dataType}" Width="150"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding description}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <ui:Button Grid.Row="1" 
                               Appearance="Primary" 
                               Content="Save Traceability Schema" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveTraceabilityCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- 4. Logic Flow Tab -->
            <TabItem Header="Process Logic (DAG)">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="Visual DAG Editor" />
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Drag nodes and draw connections to configure process logic." />
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <nodify:NodifyEditor 
                            DataContext="{Binding ViewModel.DagEditor}"
                            ItemsSource="{Binding Nodes}"
                            Connections="{Binding Connections}"
                            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                            
                            <nodify:NodifyEditor.ItemContainerStyle>
                                <Style TargetType="{x:Type nodify:ItemContainer}">
                                    <Setter Property="Location" Value="{Binding Location}" />
                                </Style>
                            </nodify:NodifyEditor.ItemContainerStyle>

                            <nodify:NodifyEditor.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:FlowNodeViewModel}">
                                    <nodify:Node Header="{Binding StepType}"
                                                 Content="{Binding Id}">
                                        <nodify:Node.Input>
                                            <nodify:NodeInput Header="In" IsConnected="True"/>
                                        </nodify:Node.Input>
                                        <nodify:Node.Output>
                                            <nodify:NodeOutput Header="Out" IsConnected="True"/>
                                        </nodify:Node.Output>
                                    </nodify:Node>
                                </DataTemplate>
                            </nodify:NodifyEditor.ItemTemplate>

                            <nodify:NodifyEditor.ConnectionTemplate>
                                <DataTemplate DataType="{x:Type vm:FlowConnectionViewModel}">
                                    <nodify:Connection Source="{Binding Source.Location}"
                                                       Target="{Binding Target.Location}" />
                                </DataTemplate>
                            </nodify:NodifyEditor.ConnectionTemplate>

                        </nodify:NodifyEditor>
                    </Border>

                    <ui:Button Grid.Row="2" 
                               Appearance="Primary" 
                               Content="Save Logic Flow" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveDagCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
