<Page
    x:Class="Poplar.Views.Pages.Manufacturing.ProductDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:nodify="https://miroiu.github.io/nodify"
    xmlns:stump="clr-namespace:uniffi.stump"
    xmlns:local="clr-namespace:Poplar.Views.Pages.Manufacturing"
    xmlns:vm="clr-namespace:Poplar.ViewModels.Pages.Manufacturing"
    Title="Product Configuration Hub"
    xmlns:helpers="clr-namespace:Poplar.Helpers"
    d:DataContext="{d:DesignInstance vm:ProductDetailsViewModel, IsDesignTimeCreatable=False}"
    d:DesignHeight="600"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <helpers:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />
        <helpers:BoolToMappingTextConverter x:Key="BoolToMappingTextConverter" />

        <!-- Premium Device Selection Card Style -->
        <Style x:Key="DeviceCardCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CardBorder"
                                Width="220"
                                Height="140"
                                Margin="0,0,16,16"
                                CornerRadius="16"
                                BorderThickness="1.5"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                Padding="16"
                                Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Row 0: Icon Badge & Checkmark -->
                                <Grid Grid.Row="0">
                                    <!-- Icon Badge on Left -->
                                    <Border x:Name="IconBadge"
                                            Width="36"
                                            Height="36"
                                            CornerRadius="10"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Desktop24" 
                                                       x:Name="CpuIcon"
                                                       Filled="False"
                                                       FontSize="18"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Checkmark on Right -->
                                    <ui:SymbolIcon x:Name="CheckIcon" 
                                                   Symbol="CheckmarkCircle24" 
                                                   Filled="True"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}" 
                                                   HorizontalAlignment="Right" 
                                                   VerticalAlignment="Center" 
                                                   Visibility="Collapsed" />
                                </Grid>

                                <!-- Row 2: Device Info -->
                                <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding name}" 
                                               FontWeight="Bold" 
                                               FontSize="15" 
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,0,0,4" />
                                    <TextBlock FontSize="10" 
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding protocol, Mode=OneWay}" />
                                        <Run Text=" PROTOCOL" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Triggers for hover and selection states -->
                        <ControlTemplate.Triggers>
                            <!-- Hover state -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource ControlStrokeColorSecondaryBrush}" />
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            
                            <!-- Checked state -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                                <Setter TargetName="CheckIcon" Property="Visibility" Value="Visible" />
                                <Setter TargetName="IconBadge" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                <Setter TargetName="CpuIcon" Property="Foreground" Value="White" />
                                <Setter TargetName="CpuIcon" Property="Filled" Value="True" />
                            </Trigger>
                            
                            <!-- Checked + Hover state -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorSecondaryBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Transparent" 
                           Command="{Binding ViewModel.NavigateBackCommand}" 
                           Icon="{ui:SymbolIcon ArrowLeft24}" 
                           Margin="0,0,16,0"
                           Padding="8,4"/>
                <TextBlock
                    FontSize="28"
                    FontWeight="Bold"
                    Text="{Binding ViewModel.ProductName, FallbackValue='Product Details'}" />
            </StackPanel>
            <TextBlock
                Margin="48,4,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Manage hardware associations, data tags, traceability schemas, and processing logic." />
        </StackPanel>

        <!-- Configuration Hub Tabs -->
        <TabControl Grid.Row="1">
            
            <!-- 1. Overview & Hardware Tab -->
            <TabItem Header="Hardware Integration">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Associated Devices" />
                        <TextBlock FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Text="Select which devices are responsible for manufacturing this product." Margin="0,4,0,0"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding ViewModel.AvailableDevices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DeviceSelectionItem}">
                                    <CheckBox Style="{StaticResource DeviceCardCheckBoxStyle}" 
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <ui:Button Grid.Row="2" 
                               Appearance="Primary" 
                               Content="Save Hardware Configuration" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveHardwareCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- 2. PLC Tags Tab -->
            <TabItem Header="PLC Tag Mapping">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Action Bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Right">
                        <ui:Button Appearance="Secondary" 
                                   Content="Bulk Import" 
                                   Icon="{ui:SymbolIcon DocumentAdd24}"
                                   Command="{Binding ViewModel.BulkImportTagsCommand}" 
                                   Margin="0,0,8,0" />
                        <ui:Button Appearance="Secondary" 
                                   Content="Add Tag" 
                                   Icon="{ui:SymbolIcon Add24}"
                                   Command="{Binding ViewModel.AddTagCommand}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ViewModel.PlcTags}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tag Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" />
                            <DataGridComboBoxColumn Header="Direction" 
                                                    SelectedItemBinding="{Binding Direction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <DataGridComboBoxColumn.ItemsSource>
                                    <x:Array Type="{x:Type stump:PlcTagDirection}">
                                        <stump:PlcTagDirection>HmiToPlc</stump:PlcTagDirection>
                                        <stump:PlcTagDirection>PlcToHmi</stump:PlcTagDirection>
                                    </x:Array>
                                </DataGridComboBoxColumn.ItemsSource>
                            </DataGridComboBoxColumn>
                            <DataGridTextColumn Header="Byte" Binding="{Binding ByteOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            <DataGridTextColumn Header="Bit" Binding="{Binding BitOffset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                            <DataGridTextColumn Header="Data Type" Binding="{Binding ValueType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            
                            <!-- Delete Column -->
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:Button Appearance="Transparent" 
                                                   Icon="{ui:SymbolIcon Delete24}" 
                                                   Foreground="{DynamicResource PaletteRedBrush}"
                                                   Command="{Binding DataContext.ViewModel.DeleteTagCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ui:Button Grid.Row="2" 
                               Appearance="Primary" 
                               Content="Save Tag Mappings" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveTagsCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <!-- 3. Traceability Tab -->
            <TabItem Header="Audit &amp; Traceability">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Action Bar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12" HorizontalAlignment="Right">
                        <ui:Button Appearance="Secondary" 
                                   Content="Add Item" 
                                   Icon="{ui:SymbolIcon Add24}"
                                   Command="{Binding ViewModel.AddTraceabilityItemCommand}" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding ViewModel.TraceabilityItems}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item Name" Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="200" />
                            <DataGridTextColumn Header="Data Type" Binding="{Binding DataType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            
                            <!-- Delete Column -->
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ui:Button Appearance="Transparent" 
                                                   Icon="{ui:SymbolIcon Delete24}" 
                                                   Foreground="{DynamicResource PaletteRedBrush}"
                                                   Command="{Binding DataContext.ViewModel.DeleteTraceabilityItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                   CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ui:Button Grid.Row="2" 
                               Appearance="Primary" 
                               Content="Save Traceability Schema" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveTraceabilityCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

            <TabItem Header="Process Logic (DAG)">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" /> <!-- Left Palette -->
                        <ColumnDefinition Width="*" />   <!-- Editor -->
                        <ColumnDefinition Width="300" /> <!-- Right Panel -->
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 1. Step Palette -->
                    <Border Grid.Column="0" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="PROCESS STEPS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,12" />
                            <ListBox ItemsSource="{Binding ViewModel.DagEditor.StepPalette}" Background="Transparent" BorderThickness="0"
                                     PreviewMouseLeftButtonDown="OnStepPalettePreviewMouseLeftButtonDown">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type stump:StepMetadata}">
                                        <Border Margin="0,0,0,8" Padding="12" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding stepType}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                                <TextBlock Text="{Binding displayName}" FontWeight="SemiBold" Margin="0,2,0,0" />
                                                <TextBlock Text="{Binding description}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- 2. Nodify Editor -->
                    <Border Grid.Column="1" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                        <Grid>
                            <nodify:NodifyEditor 
                                DataContext="{Binding ViewModel.DagEditor}"
                                ItemsSource="{Binding Nodes}"
                                Connections="{Binding Connections}"
                                SelectedItem="{Binding SelectedItem}"
                                DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                                ConnectionCompletedCommand="{Binding CreateConnectionCommand}"
                                AllowDrop="True"
                                Drop="OnNodifyEditorDrop"
                                Background="Transparent">
                                
                                <nodify:NodifyEditor.InputBindings>
                                    <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
                                    <KeyBinding Key="Backspace" Command="{Binding DeleteSelectedCommand}" />
                                </nodify:NodifyEditor.InputBindings>

                                <nodify:NodifyEditor.PendingConnection>
                                    <nodify:PendingConnection CompletedCommand="{Binding CreateConnectionCommand}" />
                                </nodify:NodifyEditor.PendingConnection>
                                
                                <nodify:NodifyEditor.Resources>
                                    <Style TargetType="{x:Type nodify:PendingConnection}">
                                        <Setter Property="Stroke" Value="{DynamicResource SystemFillColorSuccessBrush}" />
                                        <Setter Property="StrokeDashArray" Value="2 2" />
                                    </Style>
                                </nodify:NodifyEditor.Resources>
                                
                                <nodify:NodifyEditor.ItemContainerStyle>
                                    <Style TargetType="{x:Type nodify:ItemContainer}">
                                        <Setter Property="Location" Value="{Binding Location}" />
                                    </Style>
                                </nodify:NodifyEditor.ItemContainerStyle>

                                <nodify:NodifyEditor.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:FlowNodeViewModel}">
                                        <nodify:Node Header="{Binding DisplayName}">
                                            <nodify:Node.HeaderTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Visibility="{Binding DataContext.IsEntry, RelativeSource={RelativeSource AncestorType=nodify:Node}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}" Padding="6,2" CornerRadius="4" Margin="0,0,8,0">
                                                            <TextBlock Text="START" FontSize="9" FontWeight="Bold" Foreground="White" />
                                                        </Border>
                                                        <TextBlock Text="{Binding}" FontWeight="Bold" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </nodify:Node.HeaderTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <nodify:NodeInput Grid.Column="0" Header="In" IsConnected="True" 
                                                                  DataContext="{Binding}"
                                                                  Anchor="{Binding InputAnchor, Mode=OneWayToSource}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Id}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,10" Opacity="0.5" />
                                                <nodify:NodeOutput Grid.Column="2" Header="Out" IsConnected="True" 
                                                                   DataContext="{Binding}"
                                                                   Anchor="{Binding OutputAnchor, Mode=OneWayToSource}" />
                                            </Grid>
                                        </nodify:Node>
                                    </DataTemplate>
                                </nodify:NodifyEditor.ItemTemplate>

                                <nodify:NodifyEditor.ConnectionTemplate>
                                    <DataTemplate DataType="{x:Type vm:FlowConnectionViewModel}">
                                        <nodify:Connection Source="{Binding Source.OutputAnchor}"
                                                           Target="{Binding Target.InputAnchor}" />
                                    </DataTemplate>
                                </nodify:NodifyEditor.ConnectionTemplate>
                            </nodify:NodifyEditor>

                            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Right" Margin="12" Orientation="Horizontal">
                                <ui:Button Content="Auto Layout" Command="{Binding ViewModel.DagEditor.AutoLayoutCommand}" Appearance="Secondary" Margin="0,0,8,0" />
                                <ui:Button Icon="{ui:SymbolIcon Delete24}" Command="{Binding ViewModel.DagEditor.DeleteSelectedCommand}" Appearance="Secondary" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 3. Property Panel -->
                    <Border Grid.Column="2" Margin="12,0,0,0" Padding="16" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                        <Grid>
                            <TextBlock Text="Select a node or connection to configure" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" 
                                       Visibility="{Binding ViewModel.DagEditor.SelectedItem, Converter={StaticResource NullToVisibilityConverter}}" />
                            
                            <!-- Node Properties -->
                            <ScrollViewer Visibility="{Binding ViewModel.DagEditor.SelectedNode, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel DataContext="{Binding ViewModel.DagEditor.SelectedNode}">
                                    <TextBlock Text="{Binding StepType}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PaletteGoldBrush}" />
                                    <TextBlock Text="{Binding DisplayName}" FontSize="18" FontWeight="Bold" Margin="0,4,0,16" />

                                    <CheckBox Content="Set as Entry Node" IsChecked="{Binding IsEntry}" Margin="0,0,0,16" />

                                    <TextBlock Text="INPUT PARAMETERS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:StepParamViewModel}">
                                                <StackPanel Margin="0,0,0,12">
                                                    <Grid Margin="0,0,0,4">
                                                        <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold" />
                                                        <ui:Button Content="{Binding IsMapped, Converter={StaticResource BoolToMappingTextConverter}}" 
                                                                   HorizontalAlignment="Right" Padding="4,2" FontSize="9"
                                                                   Command="{Binding ToggleMappingCommand}" />
                                                    </Grid>
                                                    
                                                    <ui:TextBox Visibility="{Binding IsMapped, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                                                Text="{Binding MappingKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="VARIABLE_NAME" />
                                                    
                                                    <ContentControl Content="{Binding}" Visibility="{Binding IsMapped, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                        <ContentControl.Style>
                                                            <Style TargetType="ContentControl">
                                                                <Setter Property="ContentTemplate">
                                                                    <Setter.Value>
                                                                        <DataTemplate>
                                                                            <ui:TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="{Binding Description}" />
                                                                        </DataTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ParamType}" Value="DeviceName">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.Devices, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                              SelectedValuePath="name" DisplayMemberPath="name"
                                                                                              SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              HorizontalAlignment="Stretch" />
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ParamType}" Value="PlcAddress">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <ComboBox ItemsSource="{Binding DataContext.ViewModel.PlcTags, RelativeSource={RelativeSource AncestorType=Page}}"
                                                                                              SelectedValuePath="FormattedAddress" DisplayMemberPath="DisplayString"
                                                                                              SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                              HorizontalAlignment="Stretch" />
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding DataType}" Value="bool">
                                                                        <Setter Property="ContentTemplate">
                                                                            <Setter.Value>
                                                                                <DataTemplate>
                                                                                    <CheckBox IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Content="{Binding Description}" />
                                                                                </DataTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ContentControl.Style>
                                                    </ContentControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="0,8" />
                                    <TextBlock Text="OUTPUT MAPPINGS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding OutputToContext}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DataMappingViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0" Text="{Binding SourceKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Source" FontSize="10" />
                                                    <ui:SymbolIcon Grid.Column="1" Symbol="ArrowRight24" Margin="4,0" />
                                                    <ui:TextBox Grid.Column="2" Text="{Binding TargetKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Context Key" FontSize="10" />
                                                    <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.DeleteOutputMappingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                               CommandParameter="{Binding}" Margin="4,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:Button Content="Add Output Mapping" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddOutputMappingCommand}" FontSize="10" HorizontalAlignment="Left" Margin="0,4,0,0" />

                                    <TextBlock Text="TRACEABILITY MAPPINGS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,16,0,8" />
                                    <ItemsControl ItemsSource="{Binding OutputToTrace}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:DataMappingViewModel}">
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox Grid.Column="0" Text="{Binding SourceKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Source" FontSize="10" />
                                                    <ui:SymbolIcon Grid.Column="1" Symbol="ArrowRight24" Margin="4,0" />
                                                    <ui:TextBox Grid.Column="2" Text="{Binding TargetKey, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Trace Field" FontSize="10" />
                                                    <ui:Button Grid.Column="3" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent" 
                                                               Command="{Binding DataContext.DeleteTraceMappingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                               CommandParameter="{Binding}" Margin="4,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <ui:Button Content="Add Trace Mapping" Icon="{ui:SymbolIcon Add24}" Command="{Binding AddTraceMappingCommand}" FontSize="10" HorizontalAlignment="Left" Margin="0,4,0,0" />
                                    
                                    <Separator Margin="0,16" />
                                    <TextBlock Text="RETRY POLICY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="8" Padding="12">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Max Retries" VerticalAlignment="Center" FontSize="11" />
                                                <ui:NumberBox Value="{Binding RetryPolicy.MaxRetries}" HorizontalAlignment="Right" Width="80" Minimum="0" Maximum="10" />
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="Interval (ms)" VerticalAlignment="Center" FontSize="11" />
                                                <ui:NumberBox Value="{Binding RetryPolicy.IntervalMs}" HorizontalAlignment="Right" Width="80" Minimum="100" SpinButtonPlacementMode="Compact" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Connection Properties -->
                            <ScrollViewer Visibility="{Binding ViewModel.DagEditor.SelectedConnection, Converter={StaticResource NotNullToVisibilityConverter}}">
                                <StackPanel DataContext="{Binding ViewModel.DagEditor.SelectedConnection}">
                                    <TextBlock Text="CONNECTION" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource PaletteGoldBrush}" />
                                    <TextBlock Text="Transition Condition" FontSize="18" FontWeight="Bold" Margin="0,4,0,16" />

                                    <TextBlock Text="CONDITION TYPE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                    <ComboBox SelectedValue="{Binding ConditionType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                              SelectedValuePath="Tag"
                                              HorizontalAlignment="Stretch" Margin="0,0,0,16">
                                        <ComboBoxItem Content="Fallback (Default)" Tag="Fallback" />
                                        <ComboBoxItem Content="Status" Tag="Status" />
                                        <ComboBoxItem Content="Variable" Tag="Variable" />
                                    </ComboBox>

                                    <!-- Status Input -->
                                    <StackPanel Margin="0,0,0,16">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConditionType}" Value="Status">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="EXPECTED STATUS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                        <ui:NumberBox Value="{Binding StatusValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" />
                                    </StackPanel>

                                    <!-- Variable Input -->
                                    <StackPanel Margin="0,0,0,16">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ConditionType}" Value="Variable">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        
                                        <TextBlock Text="VARIABLE KEY" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                        <ui:TextBox Text="{Binding VariableKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="e.g. plc_val" Margin="0,0,0,12" />

                                        <TextBlock Text="OPERATOR" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                        <ComboBox SelectedValue="{Binding VariableOperator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  SelectedValuePath="Content"
                                                  HorizontalAlignment="Stretch" Margin="0,0,0,12">
                                            <ComboBoxItem Content="==" />
                                            <ComboBoxItem Content="!=" />
                                            <ComboBoxItem Content="&gt;" />
                                            <ComboBoxItem Content="&lt;" />
                                            <ComboBoxItem Content="&gt;=" />
                                            <ComboBoxItem Content="&lt;=" />
                                            <ComboBoxItem Content="in_range" />
                                        </ComboBox>

                                        <TextBlock Text="EXPECTED VALUE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,8" />
                                        <ui:TextBox Text="{Binding VariableExpectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="Value" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <ui:Button Grid.Row="1" Grid.ColumnSpan="3" 
                               Appearance="Primary" 
                               Content="Save Logic Flow" 
                               Icon="{ui:SymbolIcon Save24}"
                               Command="{Binding ViewModel.SaveDagCommand}" 
                               Margin="0,16,0,0" 
                               HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>
