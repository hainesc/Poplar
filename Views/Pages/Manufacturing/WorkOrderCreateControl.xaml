<UserControl
    x:Class="Poplar.Views.Pages.Manufacturing.WorkOrderCreateControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="350"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel Margin="0,10,0,0">
        <!-- Title Input -->
        <TextBlock
            Margin="0,0,0,8"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="BATCH OR WORK ORDER TITLE" />
        <ui:TextBox
            Margin="0,0,0,20"
            FontSize="14"
            Padding="12,14"
            PlaceholderText="e.g. Batch #2026-XA-001"
            Text="{Binding OrderTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <!-- Product Selection -->
        <TextBlock
            Margin="0,0,0,8"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="SELECT ASSOCIATED PRODUCT DNA" />
        <ComboBox
            Margin="0,0,0,20"
            Padding="12,10"
            HorizontalAlignment="Stretch"
            ItemsSource="{Binding Products}"
            DisplayMemberPath="name"
            SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
            FontSize="14" />

        <!-- Quantity Input -->
        <TextBlock
            Margin="0,0,0,8"
            FontSize="11"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="TARGET PRODUCTION QUANTITY" />
        <ui:NumberBox
            Margin="0,0,0,10"
            Padding="12,12"
            Value="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Minimum="1"
            Maximum="9999999"
            FontSize="16"
            FontWeight="SemiBold"
            HorizontalAlignment="Stretch"
            SpinButtonPlacementMode="Compact" />
    </StackPanel>
</UserControl>
