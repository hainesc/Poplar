<Page
    x:Class="Poplar.Views.Pages.Manufacturing.ProductsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Poplar.Views.Pages.Manufacturing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Poplar.ViewModels.Pages.Manufacturing"
    Title="Product Catalog"
    d:DataContext="{d:DesignInstance local:ProductsPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock
                FontSize="28"
                FontWeight="Bold"
                Text="Product Catalog" />
            <TextBlock
                Margin="0,4,0,0"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Define and configure manufactured goods, tags, and traceability" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding ViewModel.Products}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProductItemViewModel}">
                        <ui:Card
                            Width="260"
                            Margin="0,0,16,16"
                            Padding="0"
                            Cursor="Hand">
                            <ui:Card.InputBindings>
                                <MouseBinding Gesture="LeftClick" 
                                              Command="{Binding DataContext.ViewModel.SelectProductCommand, RelativeSource={RelativeSource AncestorType=local:ProductsPage}}"
                                              CommandParameter="{Binding}"/>
                            </ui:Card.InputBindings>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Card Header -->
                                <Grid Grid.Row="0" Margin="16,16,16,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                        CornerRadius="8">
                                        <ui:SymbolIcon FontSize="20" Symbol="Box24" />
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                        <TextBlock
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Text="{Binding Record.name}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Record.id, StringFormat='ID: {0}'}" />
                                    </StackPanel>
                                </Grid>

                                <!-- Info Area -->
                                <StackPanel Grid.Row="1" Margin="16,0,16,16">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Link24" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center">
                                            <Run Text="{Binding Record.devices.Length, Mode=OneWay}" FontWeight="SemiBold"/>
                                            <Run Text=" Associated Devices"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <ui:SymbolIcon Symbol="Flow24" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Margin="6,0,0,0" FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Process ID: "/>
                                            <Run Text="{Binding Record.processId, TargetNullValue='None'}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Footer -->
                                <Border
                                    Grid.Row="2"
                                    Padding="16,8"
                                    Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,1,0,0">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="10"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        Text="Click to Configure" />
                                </Border>
                            </Grid>
                        </ui:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Add Button -->
        <ui:Button
            Grid.Row="1"
            Width="56"
            Height="56"
            Margin="0,0,24,24"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Appearance="Primary"
            Command="{Binding ViewModel.AddProductCommand}"
            CornerRadius="28"
            Icon="{ui:SymbolIcon Add24}" />
    </Grid>
</Page>
