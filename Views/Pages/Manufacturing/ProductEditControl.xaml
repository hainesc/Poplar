<UserControl
    x:Class="Poplar.Views.Pages.Manufacturing.ProductEditControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel Margin="0,10,0,0">
        <TextBlock
            Margin="0,0,0,8"
            FontSize="12"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="UNIVERSAL ASSET NAME" />
        <ui:TextBox
            x:Name="ProductNameBox"
            Margin="0,0,0,16"
            FontSize="16"
            Padding="12,16"
            PlaceholderText="e.g. Master Drive Logic"
            Text="{Binding ProductName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
    </StackPanel>
</UserControl>
