<UserControl
    x:Class="Poplar.Views.Pages.Manufacturing.DeviceEditControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:Poplar.ViewModels.Pages.Manufacturing"
    d:DesignHeight="500"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <StackPanel Margin="0,0,0,16" Orientation="Vertical">
        <ui:TextBox
            Margin="0,0,0,12"
            PlaceholderText="Device Name (e.g. PLC_Line1)"
            Text="{Binding ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock
                    Margin="4,0,0,4"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="Category" />
                <ComboBox
                    HorizontalAlignment="Stretch"
                    SelectedValue="{Binding ViewModel.DeviceType, Mode=TwoWay}"
                    SelectedValuePath="Tag">
                    <ComboBoxItem Content="PLC Controller" Tag="plc" />
                    <ComboBoxItem Content="Barcode Scanner" Tag="scanner" />
                    <ComboBoxItem Content="Label Printer" Tag="printer" />
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock
                    Margin="4,0,0,4"
                    FontSize="11"
                    FontWeight="SemiBold"
                    Text="Protocol" />
                <ComboBox
                    HorizontalAlignment="Stretch"
                    SelectedValue="{Binding ViewModel.Protocol, Mode=TwoWay}"
                    SelectedValuePath="Tag">
                    <ComboBoxItem
                        Content="Siemens S7"
                        Tag="s7"
                        Visibility="{Binding ViewModel.DeviceType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=plc}" />
                    <ComboBoxItem
                        Content="Serial (RS232)"
                        Tag="serial"
                        Visibility="{Binding ViewModel.DeviceType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=scanner}" />
                    <ComboBoxItem
                        Content="HTTP Rest"
                        Tag="http"
                        Visibility="{Binding ViewModel.DeviceType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=printer|scanner}" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Dynamic Configuration Sections -->
        <Border
            Padding="12"
            Background="{DynamicResource ControlFillColorSecondaryBrush}"
            CornerRadius="8">
            <StackPanel>
                <!-- S7 Config -->
                <StackPanel Visibility="{Binding ViewModel.Protocol, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=s7}">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Text="S7 Connection" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="100" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            PlaceholderText="IPv4 Address"
                            Text="{Binding ViewModel.Host, Mode=TwoWay}" />
                        <ui:NumberBox
                            Grid.Column="1"
                            ClearButtonEnabled="False"
                            Value="{Binding ViewModel.Port, Mode=TwoWay}" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock
                                Margin="4,0,0,2"
                                FontSize="10"
                                Text="Rack" />
                            <ui:NumberBox Value="{Binding ViewModel.Rack, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="4,0,4,0">
                            <TextBlock
                                Margin="4,0,0,2"
                                FontSize="10"
                                Text="Slot" />
                            <ui:NumberBox Value="{Binding ViewModel.Slot, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="4,0,0,0">
                            <TextBlock
                                Margin="4,0,0,2"
                                FontSize="10"
                                Text="DB" />
                            <ui:NumberBox Value="{Binding ViewModel.DbNumber, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock
                            Margin="4,0,0,2"
                            FontSize="10"
                            Text="Station ID" />
                        <ui:NumberBox Value="{Binding ViewModel.Station, Mode=TwoWay}" />
                    </StackPanel>

                    <!-- S7 Health Check -->
                    <Border
                        Margin="0,12,0,0"
                        Padding="8"
                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                        CornerRadius="4">
                        <StackPanel>
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Text="Heartbeat Monitoring" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                    <TextBlock
                                        Margin="4,0,0,2"
                                        FontSize="10"
                                        Text="Offset (Bytes)" />
                                    <ui:NumberBox Value="{Binding ViewModel.HbOffset, Mode=TwoWay}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <TextBlock
                                        Margin="4,0,0,2"
                                        FontSize="10"
                                        Text="Interval (ms)" />
                                    <ui:NumberBox Value="{Binding ViewModel.HbInterval, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Serial Config -->
                <StackPanel Visibility="{Binding ViewModel.Protocol, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=serial}">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Text="Serial Interface" />
                    <ui:TextBox
                        Margin="0,0,0,8"
                        PlaceholderText="Port Path (e.g. COM1 or /dev/ttyUSB0)"
                        Text="{Binding ViewModel.SerialPort, Mode=TwoWay}" />
                    <TextBlock
                        Margin="4,0,0,2"
                        FontSize="10"
                        Text="Baud Rate" />
                    <ui:NumberBox Value="{Binding ViewModel.BaudRate, Mode=TwoWay}" />
                </StackPanel>

                <!-- HTTP Config -->
                <StackPanel Visibility="{Binding ViewModel.Protocol, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=http}">
                    <TextBlock
                        Margin="0,0,0,8"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                        Text="HTTP Endpoint" />
                    <ui:TextBox
                        Margin="0,0,0,8"
                        PlaceholderText="Hostname"
                        Text="{Binding ViewModel.Host, Mode=TwoWay}" />
                    <TextBlock
                        Margin="4,0,0,2"
                        FontSize="10"
                        Text="Port" />
                    <ui:NumberBox Value="{Binding ViewModel.Port, Mode=TwoWay}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Primary Toggle -->
        <ui:ToggleSwitch
            Margin="0,16,0,0"
            Content="Primary Controller"
            IsChecked="{Binding ViewModel.IsPrimary, Mode=TwoWay}"
            Visibility="{Binding ViewModel.DeviceType, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=plc}" />
    </StackPanel>
</UserControl>
