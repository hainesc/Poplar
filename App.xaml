<Application
    x:Class="Poplar.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:Poplar.Converters"
    xmlns:helpers="clr-namespace:Poplar.Helpers"
    xmlns:local="clr-namespace:Poplar"
    xmlns:syntax="clr-namespace:Wpf.Ui.SyntaxHighlight.Markup"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    DispatcherUnhandledException="OnDispatcherUnhandledException"
    Exit="OnExit"
    Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Premium Color Palette Brushes -->
            <SolidColorBrush x:Key="PaletteGoldBrush" Color="#DAA520" />

            <helpers:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
            <helpers:ThemeToIndexConverter x:Key="ThemeToIndexConverter" />
            <helpers:PaneDisplayModeToIndexConverter x:Key="PaneDisplayModeToIndexConverter" />
            <helpers:StringToValueConverter x:Key="StringToValueConverter" />
            <helpers:BoolToSignTextConverter x:Key="BoolToSignText" />
            <helpers:BoolToToggleHintConverter x:Key="BoolToToggleHint" />
            <helpers:BoolToToggleActionConverter x:Key="BoolToToggleAction" />
            <helpers:NullToFalseConverter x:Key="NullToFalseConverter" />
            <converters:StringToUppercaseConverter x:Key="StringToUppercaseConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
